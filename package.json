{
  "name": "task-grabber",
  "version": "1.0.0",
  "description": "Windows tray app for instant task creation",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "concurrently \"vite --config vite.config.ts\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "tsc -p tsconfig.main.json && vite build",
    "start": "electron .",
    "pack": "npm run build && electron-builder"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^8.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^24.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "wait-on": "^7.0.0"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "better-sqlite3": "^9.0.0",
    "framer-motion": "^11.0.0",
    "lucide-react": "^0.400.0",
    "msgreader": "^1.0.1",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwindcss": "^3.0.0",
    "zustand": "^4.0.0"
  }
}
